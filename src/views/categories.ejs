
<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <ul>
        <% categories.forEach(category => { %>
            <li><a href="/category/<%= category.category_id %>"><%= category.name %></a></li>
        <% }); %>
    </ul>

    <% if (user && user.role_name === 'admin') { %>
        <a href="/new-category">Add a New Category</a>
    <% } %>
</main>

<%- include('partials/footer') %>