<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <h2><%= projectDetails.title %></h2>

    <p>Description: <%= projectDetails.description %></p>
    <p>Date: <%= projectDetails.project_date.toISOString().split('T')[0] %></p>
    <p>Location: <%= projectDetails.project_location %></p>
    <p>Partner Organization: <a href="/organization/<%= projectDetails.organization_id %>"><%= projectDetails.name %></a></p>
    <p>Categories: </p>
    <ul>
        <% categories.forEach(category => { %>
            <li><a href="/category/<%= category.category_id %>"><%= category.name %></a></li>
        <% }); %>
    </ul>
    <p><a href="/assign-categories/<%= projectDetails.project_id %>">Edit Categories</a></p>
    <p><a href="/edit-project/<%= projectDetails.project_id %>">Edit Project</a></p>
</main>
<%- include('partials/footer') %>