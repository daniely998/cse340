<%- include('partials/header') %>
<main>
  <h1><%= title %></h1>

  <form action="/edit-project/<%= projectDetails.project_id %>" method="POST">
    <div class="form-group">
      <label for="title">Project Title</label>
      <input
        type="text"
        id="title"
        name="title"
        value="<%= projectDetails.title %>"
        required
        maxlength="150"
      />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        required
        maxlength="500"
      ><%= projectDetails.description %></textarea>
    </div>

    <div class="form-group">
      <label for="location">Location</label>
      <input
        type="text"
        id="location"
        name="location"
        value="<%= projectDetails.project_location %>"
        required
        maxlength="255"
      />
    </div>

    <div class="form-group">
      <label for="date">Project Date</label>
      <input
        type="date"
        id="date"
        name="date"
        value="<%= projectDetails.project_date.toISOString().split('T')[0] %>"
        required
      />
    </div>

    <div class="form-group">
      <label for="organizationId">Organization</label>
      <select id="organizationId" name="organizationId" required>
        <% organizations.forEach(organization => { %>
          <option 
            value="<%= organization.organization_id %>" 
            <%= organization.organization_id === projectDetails.organization_id ? 'selected' : '' %>>
            <%= organization.name %>
          </option>
        <% }) %>
      </select>
    </div>

    <button type="submit">Update Project</button>
  </form>
</main>
<%- include('partials/footer') %>
